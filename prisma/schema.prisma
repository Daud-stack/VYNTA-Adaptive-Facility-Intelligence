// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AssetStatus {
  ACTIVE
  MAINTENANCE
  OFFLINE
}

model Asset {
  id        String   @id @default(cuid())
  label     String   // e.g. AST-101
  name      String
  type      String
  location  String
  health    Int      @default(100)
  status    AssetStatus @default(ACTIVE)
  uptime    String   @default("100%")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("assets")
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

model Ticket {
  id          String   @id @default(cuid())
  ticketId    String   @unique // e.g. TKT-782
  title       String

  userId      String
  user        User     @relation(fields: [userId], references: [id])

  priority    TicketPriority @default(MEDIUM)
  status      TicketStatus   @default(OPEN)
  timestamp   DateTime @default(now())
  aiResponse  String?
  
  /// JSON stringified array
  aiReasoning String?
  createdAt   DateTime @default(now())

  @@map("tickets")
}

model SensorLog {
  id        String   @id @default(cuid())
  type      String   // Occupancy, PUE, Energy
  value     Float
  unit      String
  timestamp DateTime @default(now())

  @@map("sensor_logs")
}

enum Role {
  USER
  ADMIN
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  role      Role     @default(USER)
  password  String
  createdAt DateTime @default(now())

  tickets   Ticket[]

  @@map("users")
}
