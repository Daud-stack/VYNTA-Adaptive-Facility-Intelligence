{
    "$schema": "https://www.schemastore.org/package.json",
    "name": "enterprise-crm-temp",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "next dev",
        "build": "prisma generate && next build",
        "start": "next start",
        "lint": "eslint .",
        "typecheck": "tsc --noEmit",
        "postinstall": "prisma generate",
        "test:unit": "vitest run tests/unit",
        "test:component": "vitest run tests/component",
        "test:integration": "vitest run tests/integration",
        "test:e2e": "playwright test",
        "test:performance": "k6 run tests/performance/smoke.js",
        "test:security": "snyk test"
    },
    "dependencies": {
        "@neondatabase/serverless": "^1.1.0",
        "@prisma/adapter-neon": "^7.8.0",
        "@prisma/adapter-pg": "^7.8.0",
        "@prisma/client": "^7.7.0",
        "@react-three/drei": "^10.7.7",
        "@react-three/fiber": "^9.6.0",
        "@types/ws": "^8.18.1",
        "next": "16.2.3",
        "pg": "^8.22.0",
        "react": "19.2.4",
        "react-dom": "19.2.4",
        "react-is": "^19.2.7",
        "recharts": "^3.8.1",
        "three": "^0.184.0",
        "ws": "^8.21.0"
    },
    "devDependencies": {
        "@types/node": "^20",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "@types/three": "^0.184.0",
        "@vitejs/plugin-react": "^6.0.3",
        "dotenv": "^16.4.7",
        "eslint": "^9",
        "eslint-config-next": "16.2.3",
        "jest": "^29.7.0",
        "jsdom": "^29.1.1",
        "k6": "^0.0.0",
        "playwright": "^1.40.0",
        "prettier": "^3.0.0",
        "prisma": "^7.7.0",
        "snyk": "^1.1200.0",
        "typescript": "^5",
        "vitest": "^1.0.0"
    },
    "prisma": {
        "seed": "node -r dotenv/config prisma/seed.js"
    }
}
